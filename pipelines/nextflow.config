/*
 * Top-level config for the UNIFIED non-reference workflow (pipelines/main.nf).
 * The `apple_silicon` profile is the single supported execution profile for a
 * 64 GB arm64 Mac; it layers on the battle-tested conf/mac_arm64.config (conda
 * arm64 envs, local-channel repackaging, per-tool arm64 overrides).
 *
 *   nextflow run pipelines/main.nf -profile apple_silicon --bam_glob '...'
 */

manifest {
    name            = 'evolutionary-rna-state/unified-nonref'
    description      = 'Unified non-reference RNA feature workflow (editing/TE-ERV/intron-retention) off a spine BAM'
    nextflowVersion  = '>=24.04.0'
    version          = '0.1.0'
}

profiles {
    apple_silicon {
        includeConfig 'conf/mac_arm64.config'
    }
    // convenience alias
    arm64 {
        includeConfig 'conf/mac_arm64.config'
    }
}

/*
 * Disk hygiene (single Apple-Silicon workstation).
 *
 * cleanup = true: on SUCCESSFUL completion, Nextflow deletes the entire work/
 *   directory. This is the fix for the 544 GB accumulation we hit on the first
 *   cohort run: the pipeline stages ~26 intermediate BAM copies per sample
 *   across process dirs (inherent to Nextflow's resumable-DAG design), and
 *   without cleanup they persist for the whole run. Published outputs
 *   (publishDir targets, e.g. results/rnaseq_cohort/hisat2/) are NOT in work/
 *   and are untouched. Trade-off: `-resume` is unavailable AFTER a run that
 *   completed with cleanup — acceptable for production cohort runs; comment this
 *   line out for iterative debugging where you want to resume.
 *
 * NOTE: `scratch` is deliberately NOT set. On this single-disk machine, scratch
 *   defaults to system tmp on the SAME physical disk, so it does not reduce peak
 *   footprint (it would raise it). scratch only helps on HPC nodes with local
 *   scratch disk; leave it off here.
 */
cleanup = true

// Default report/timeline off unless -with-report requested (keeps arm64 runs lean)
