/*
 * Default parameters for the RNA-editing subworkflow. Loaded automatically when
 * `nextflow run pipelines/rna_editing/main.nf` is invoked (config in the script
 * dir). CLI flags and extra `-c` configs override these.
 */
params {
    help                       = false
    input                      = null
    bam_glob                   = null
    fasta                      = null
    rmsk                       = null
    outdir                     = 'results/rna_editing'

    editing_call_sites         = true
    editing_min_mapq           = 60      // HISAT2 unique-mapper MAPQ (arm64 spine); set 255 for STAR BAMs (amd64/Docker)
    editing_min_baseq          = 25
    editing_min_cov            = 10
    editing_min_freq           = 0.10
    editing_min_edit_reads     = 3
    editing_snp_bed            = null
    editing_alu_standard_only  = true
}

profiles {
    // `-profile stub_local` : parse/wire validation with NO conda env build.
    // Use together with `-stub-run`.
    stub_local {
        conda.enabled       = false
        docker.enabled      = false
        singularity.enabled = false
        process.conda       = null
    }
}
