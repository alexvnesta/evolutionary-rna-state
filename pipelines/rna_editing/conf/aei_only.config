// Override: AEI-only cohort run. The sibling nextflow.config hardcodes
// editing_call_sites=true, which CLI --editing_call_sites cannot override.
// A -c config loaded after it DOES win. AEI (Alu Editing Index) is the
// primary quantitative editing metric and always runs; genome-wide JACUSA2
// per-site calling (~2.6 h/sample) is disabled for the 40-sample cohort.
params.editing_call_sites = false
