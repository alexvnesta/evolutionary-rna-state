/*
 * Process resource directives for the RNA-editing subworkflow on this
 * Apple Silicon Mac (18 cores / 64 GB, no Docker). Layer this AFTER
 * pipelines/conf/mac_arm64.config so the executor bounds still apply:
 *   -c pipelines/conf/mac_arm64.config -c pipelines/rna_editing/conf/editing.config
 *
 * None of the editing steps load the genome into RAM the way STAR does
 * (JACUSA2 streams the BAM; the AEI pileup is region-restricted to Alu),
 * so these are all "light" (<=10 GB). BAMs are consumed from the rnaseq
 * spine -- no re-alignment here.
 */
process {
    withLabel: 'process_editing' {
        cpus     = 4
        memory   = 10.GB
        maxForks = 2          // a couple of samples in parallel; each is I/O-bound
        time     = 24.h
    }
    withLabel: 'process_light' {
        cpus     = 2
        memory   = 4.GB
        maxForks = 3
        time     = 4.h
    }
    // JACUSA2 per-site calling over the whole genome is the heaviest editing
    // step (streams every read); give it a touch more but keep it serialized-ish.
    withName: 'JACUSA2_CALL1' {
        cpus     = 6
        memory   = 10.GB
        maxForks = 1
    }
}

// Make bin/ scripts available on PATH inside every task.
// (Nextflow auto-adds <projectDir>/bin; this entrypoint's projectDir is
//  pipelines/rna_editing/, so bin/*.py are picked up automatically.)
