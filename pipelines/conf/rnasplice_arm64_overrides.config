/*
 * arm64 conda overrides for nf-core/rnasplice 1.0.4 on Apple Silicon.
 *
 * rnasplice pins samtools=1.16.1 (CUSTOM_GETCHROMSIZES + the STAR modules) and
 * samtools=1.17 (SAMTOOLS_* utility modules). Neither has an osx-arm64 conda
 * build (lowest arm64 build is 1.20). Override both to 1.21, which solves on
 * osx-arm64 and is ABI/CLI-compatible for chromsizes/index/sort/stats.
 *
 * These only affect the genome_bam source path we use on this Mac (rMATS +
 * DEXSeq + edgeR); the STAR modules are never invoked there but are overridden
 * too so a stray call would still solve.
 *
 * Applied via a second -c in run_rnasplice.sh (after mac_arm64.config).
 */
process {
    withName: '.*:CUSTOM_GETCHROMSIZES' {
        conda = "bioconda::samtools=1.21"
    }
    withName: '.*:SAMTOOLS_SORT|.*:SAMTOOLS_INDEX|.*:SAMTOOLS_STATS|.*:SAMTOOLS_FLAGSTAT|.*:SAMTOOLS_IDXSTATS' {
        conda = "bioconda::samtools=1.21"
    }
    withName: '.*:STAR_ALIGN|.*:STAR_GENOMEGENERATE' {
        conda = "bioconda::star=2.7.10a bioconda::samtools=1.21 conda-forge::gawk=5.1.0"
    }
    // DEXSeq annotation/count modules pin htseq=2.0.2 (no osx-arm64; arm64 has 2.0.5).
    withName: '.*:DEXSEQ_ANNOTATION|.*:DEXSEQ_COUNT' {
        conda = "bioconda::htseq=2.0.5"
    }
    // DEXSEQ_EXON (the differential-exon test) pins bioconductor-dexseq=1.36.0,
    // which needs s4vectors 0.28 (no osx-arm64 build). Override to dexseq=1.56.0
    // (Bioc 3.21), whose s4vectors 0.48 dep HAS an arm64 build. Same class of fix
    // as the tximeta/summarizedexperiment arm64 overrides for rnaseq.
    withName: '.*:DEXSEQ_EXON|.*:DEXSEQ_DTU' {
        conda = "bioconda::bioconductor-dexseq=1.56.0"
    }
    // rMATS pins rmats=4.1.2 (no osx-arm64; lowest arm64 is 4.3.0). rmats itself
    // only needs python; the r-base pull comes from r-pairadise 1.0.0, whose old
    // noarch builds pin r-base 3.6 (no arm64 build). Force the newer r45* build
    // (r-base >=4.5, arm64-available) so the env solves.
    withName: '.*:RMATS_PREP.*|.*:RMATS_POST.*' {
        conda = "bioconda::r-pairadise=1.0.0=r45hdfd78af_2 bioconda::rmats=4.3.0"
    }
    // edgeR pins bioconductor-edger=3.36.0 (no osx-arm64; lowest arm64 is 4.4.0,
    // Bioc 3.20). r-statmod is a conda-forge noarch/arm64 dep.
    withName: '.*:EDGER_EXON' {
        conda = "bioconda::bioconductor-edger=4.4.0 conda-forge::r-statmod=1.5.0"
    }
    // gffread pins 0.12.1 (no osx-arm64); 0.12.7 has an arm64 build.
    withName: '.*:GFFREAD.*' {
        conda = "bioconda::gffread=0.12.7"
    }
    // subread pins 2.0.1 (no osx-arm64; nearest arm64 is 2.0.8) — used by
    // DEXSeq's GTF flattening and featureCounts.
    withName: '.*:SUBREAD_FLATTENGTF|.*:SUBREAD_FEATURECOUNTS' {
        conda = "bioconda::subread=2.0.8"
    }
    // RSEM_PREPAREREFERENCE (aliased MAKE_TRANSCRIPTS_FASTA) only runs
    // rsem-prepare-reference to extract a transcripts FASTA; it bundles
    // star=2.7.10a (no osx-arm64 build) but never invokes it here. Drop STAR;
    // rsem=1.3.3 has an arm64 build with no star dependency.
    // NB: this module is imported `as MAKE_TRANSCRIPTS_FASTA`, so the runtime
    // process name is the alias, not RSEM_PREPAREREFERENCE.
    withName: '.*:MAKE_TRANSCRIPTS_FASTA|.*:RSEM_PREPAREREFERENCE' {
        conda = "bioconda::rsem=1.3.3"
    }
    // Utility processes pin sed=4.7/4.7.0 (no osx-arm64; arm64 has 4.8) and, for
    // UNTAR, grep=3.4 (arm64 has 3.11). tar=1.34 is fine. These are shell-glue
    // steps (bamlist creation, fasta preprocessing, gunzip/untar).
    withName: '.*:CREATE_BAMLIST|.*:CREATE_BAMLIST_SINGLE|.*:PREPROCESS_TRANSCRIPTS_FASTA_GENCODE|.*:CAT_FASTQ|.*:GUNZIP.*' {
        conda = "conda-forge::sed=4.8"
    }
    withName: '.*:UNTAR.*' {
        conda = "conda-forge::sed=4.8 conda-forge::grep=3.11 conda-forge::tar=1.34"
    }
}
