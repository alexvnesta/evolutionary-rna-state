/*
 * arm64 module conda overrides for nf-core/rnaseq 3.26.0
 * ------------------------------------------------------
 * Several nf-core modules pin exact tool versions that have no osx-arm64 conda
 * build (they predate Apple-Silicon packaging). Each pin below is redirected to
 * the nearest version that DOES have an osx-arm64 build (verified via the
 * anaconda.org package API); the tools are behaviourally compatible across
 * these minor bumps for this pipeline's usage.
 *
 * Tools with NO osx-arm64 build at ANY version are handled by skipping, not
 * overriding (set in run_rnaseq.sh / mac_arm64.config):
 *   - fq       (FASTQ linter)      -> params.skip_linting + explicit strandedness
 *   - rseqc    (read QC suite)     -> params.skip_rseqc
 *
 * On amd64/Docker this file is unnecessary — omit it.
 */
process {
    withName: '.*:GTF2BED' {
        conda = "conda-forge::perl=5.32.1"
    }
    withName: '.*:SUBREAD_FEATURECOUNTS' {
        conda = "bioconda::subread=2.0.8"
    }
    withName: '.*:STRINGTIE_STRINGTIE|.*:STRINGTIE_MERGE' {
        conda = "bioconda::stringtie=2.2.3"
    }
    withName: '.*:UCSC_BEDCLIP' {
        conda = "bioconda::ucsc-bedclip=482"
    }
    withName: '.*:UCSC_BEDGRAPHTOBIGWIG' {
        conda = "bioconda::ucsc-bedgraphtobigwig=482"
    }
    // GENCODE transcript-fasta preprocessing (on the Salmon path) uses sed.
    withName: '.*PREPROCESS_TRANSCRIPTS_FASTA_GENCODE|.*GTF2BED|.*RSEM_MERGE_COUNTS' {
        conda = "conda-forge::sed=4.8 conda-forge::perl=5.32.1"
    }
}

process {
    withName: '.*:ALIGN_STAR:STAR_ALIGN' {
        // arm64 conda STAR 2.7.11b (the ONLY osx-arm64 build) has a broken
        // --quantMode TranscriptomeSAM: the transcriptome loader resolves
        // geneInfo.tab against an EMPTY genomeDir prefix ("could not open input
        // file /geneInfo.tab"), even on a freshly-built same-version index with
        // geneInfo.tab present. Reproduced standalone; not a config/2-pass/sjdb
        // issue. Genome alignment itself works fine. So we emit only the genome
        // BAM (SortedByCoordinate) and quantify expression via Salmon
        // pseudo-alignment (--pseudo_aligner salmon), which needs no
        // transcriptome BAM. The genome BAMs feed the splicing / intron-retention
        // / RNA-editing / TE-ERV subworkflows, which is their primary purpose here.
        // Re-enable --quantMode TranscriptomeSAM on amd64/Docker.
        ext.args = [
            '--outSAMtype BAM SortedByCoordinate',
            '--readFilesCommand zcat',
            '--runRNGseed 0',
            '--outFilterMultimapNmax 20',
            '--alignSJDBoverhangMin 1',
            '--outSAMstrandField intronMotif',
            '--outSAMattributes NH HI AS NM MD'
        ].join(' ')
    }
}

process {
    // bioconductor-tximeta=1.20.1 (Bioc 3.18) pins s4vectors 0.40.x which has no
    // osx-arm64 build; arm64 only ships s4vectors 0.44/0.48 (Bioc 3.20+). Bump
    // tximeta to 1.24.0 (Bioc 3.20), which solves on osx-arm64. tximport's
    // transcript->gene summarisation API is unchanged across these versions.
    withName: '.*:TXIMETA_TXIMPORT' {
        // tximeta needs GenomeInfoDb, which needs the GenomeInfoDbData DATA package.
        // The bioconda genomeinfodbdata package installs a post-link script that
        // downloads the payload from bioconductor.org's archive CDN
        // (mghp.osn.xsede.org) — blocked in this sandbox — so a solver-built env
        // has GenomeInfoDbData registered but with an EMPTY R library dir, and
        // GenomeInfoDb fails to load. We instead point at a PERSISTENT env
        // pre-seeded with GenomeInfoDbData_1.2.15 (fetched from the current
        // Bioconductor release, R CMD INSTALL'd). See
        // pipelines/scripts/build_tximeta_env.sh. NXF_TXIMETA_ENV is exported by env.sh.
        conda = System.getenv('NXF_TXIMETA_ENV')
    }
}

process {
    // bioconductor-summarizedexperiment=1.32.0 (Bioc 3.18) pins s4vectors 0.40.x
    // (no osx-arm64 build), same root cause as tximeta. Bump to 1.36.0 (Bioc 3.20),
    // which solves on osx-arm64. The SummarizedExperiment container API used by
    // the SE_* processes is stable across these versions.
    withName: '.*:SE_.*|.*:SUMMARIZEDEXPERIMENT.*' {
        conda = "bioconda::bioconductor-summarizedexperiment=1.36.0"
    }
}

process {
    // MultiQC's module environment.yml pulls the `referencing` package, which
    // bundles an etc/conda/test-files/.../.git dir that the sandbox's
    // git-protection blocks — micromamba aborts extraction and corrupts the pkg
    // cache. We serve a repackaged, .git-stripped `referencing` from a local
    // channel (NXF_LOCAL_CHANNEL, see build_local_channel.sh). But a module that
    // supplies its conda env as a .yml FILE uses that file's own `channels:` list
    // and IGNORES conda.channels — so the local channel never applies. Override
    // MultiQC to a STRING conda spec instead, which resolves against conda.channels
    // (local channel prepended) and picks up the fixed referencing build.
    // MultiQC 1.33 breaks with the newest rich/rich-click on osx-arm64:
    //   - unconstrained solve pulls python 3.14 + rich 15 + rich-click 1.9.8;
    //   - MultiQC/rich-click do `import rich; rich.panel.Panel(...)`, but rich 15
    //     no longer eagerly imports its submodules, so this raises
    //     "module 'rich' has no attribute 'panel'" and the run dies.
    // Pin python=3.12, rich=13.*, rich-click<1.8 (the generation MultiQC 1.33 was
    // built against). Verified: MultiQC runs to completion and writes the HTML
    // report on real pilot data. (multiqc 1.33 declares python >=3.8,!=3.14.1.)
    withName: '.*:MULTIQC' {
        conda = "conda-forge::python=3.12 conda-forge::rich=13 conda-forge::rich-click=1.7.4 bioconda::multiqc=1.33"
    }
}
