/*
 * Nextflow config for a single Apple Silicon Mac: 18 cores, 64 GB RAM, arm64, no Docker.
 * Execution via conda (native arm64 / noarch tool envs). Source pipelines/env.sh first.
 *
 * Usage:  nextflow run nf-core/rnaseq -profile conda -c pipelines/conf/mac_arm64.config ...
 */

conda.enabled          = true
docker.enabled         = false
singularity.enabled    = false
// The local channel (NXF_LOCAL_CHANNEL) is prepended at highest priority: it holds
// packages we had to repackage to strip sandbox-hostile paths. Specifically the
// `referencing` package (a MultiQC dependency) bundles an `etc/conda/test-files/
// .../.git` directory whose creation the sandbox's git-protection blocks, aborting
// extraction and corrupting the package cache. We rebuild it with that path removed
// (see pipelines/scripts/build_local_channel.sh) and serve it from a file:// channel.
conda.channels         = [System.getenv('NXF_LOCAL_CHANNEL'), 'conda-forge', 'bioconda'].findAll { it }
// Give conda time to solve arm64 envs on first run
conda.createTimeout    = '2 h'
// This machine's solver is micromamba (exposed as conda/mamba shims via pipelines/env.sh).
// useMamba routes env creation through the (much faster) mamba/micromamba solver.
conda.useMamba         = true

// Single-machine executor: bound total concurrent CPU/RAM so we never oversubscribe 64 GB.
executor {
    name           = 'local'
    cpus           = 16       // leave 2 cores for the OS / Nextflow
    memory         = '58 GB'  // leave ~6 GB headroom
    queueSize      = 12
}

process {
    // Default ceilings
    cpus   = 4
    memory = 8.GB
    time   = 24.h

    resourceLimits = [ cpus: 16, memory: 58.GB, time: 240.h ]

    // STAR alignment is the memory hog on a human genome (~32-38 GB).
    // Serialize it (maxForks 1) and give it room; nothing else runs alongside it.
    withName: '.*:STAR_ALIGN.*|.*STAR_GENOMEGENERATE.*' {
        cpus     = 12
        memory   = 40.GB
        maxForks = 1
    }
    // Salmon quant is light; allow a couple in parallel.
    withName: '.*SALMON_QUANT.*|.*QUANTIFY.*' {
        cpus     = 6
        memory   = 10.GB
        maxForks = 2
    }
    // Trimming / QC — light, parallel.
    withName: '.*FASTP.*|.*FASTQC.*|.*TRIMGALORE.*' {
        cpus     = 4
        memory   = 6.GB
        maxForks = 3
    }
    withName: '.*SORT.*|.*SAMTOOLS.*|.*MARKDUP.*' {
        cpus     = 4
        memory   = 12.GB
    }
}

// Bound the WORK footprint: clean intermediate work dirs as soon as outputs are published.
// (cleanup after successful completion; keep -resume friendliness during a run)
cleanup = false   // set true in production once validated

// NOTE: reference paths (fasta/gtf) and the prebuilt STAR index are passed on the
// command line by pipelines/scripts/run_rnaseq.sh using absolute repo paths — NOT here,
// because ${projectDir} in a pipeline config resolves to the pipeline install dir,
// not this repository.

params {
    // We use GENCODE annotation, so enable GENCODE-aware handling (rnaseq/rnasplice).
    gencode        = true
    // Booleans set here (typed) rather than as CLI flags — nf-schema strict
    // validation rejects `--flag true` on the command line as a string.
    save_reference = true
    skip_bbsplit   = true
    // `fq` (nf-core FASTQ linter) has NO osx-arm64 conda build (linux-64/
    // linux-aarch64/osx-64 only), so skip linting.
    // IMPORTANT: `fq` is ALSO required by the strandedness=auto path
    // (FASTQ_SUBSAMPLE_FQ_SALMON), so on arm64 each samplesheet row must set an
    // EXPLICIT strandedness (not 'auto'). The production sheet is left at 'auto'
    // to record intent and MUST be resolved before the real run — see
    // pipelines/rnaseq/STRANDEDNESS_NOTE.md. The pilot sheet uses an explicit
    // placeholder value only so the arm64 validation run can proceed.
    skip_linting   = true
    // NOTE: RSeQC is NOT skipped — rseqc=5.0.4 is a noarch conda package and
    // its r-base=4.3 dep resolves on osx-arm64 (env solve verified). It runs natively.

    // Qualimap crashes ("Abort trap: 6" / JVM SIGABRT) on osx-arm64 during its
    // plot-creation phase AFTER fully analysing the BAM (a known Qualimap/JVM
    // instability on Apple Silicon, not a data problem — it processed all 79M
    // reads of the pilot BAM before aborting). It is a non-essential QC step, so
    // skip it on arm64. Re-enable on amd64/Docker.
    skip_qualimap  = true

    // star_ignore_sjdbgtf is a harmless no-op now that the aligner is HISAT2
    // (see run_rnaseq.sh: the osx-arm64 STAR 2.7.11b build ingests 0 reads). Left
    // set so that flipping the aligner back to STAR on amd64/Docker keeps the
    // index's built-in sjdb behaviour without re-editing this file.
    star_ignore_sjdbgtf = true
}

// macOS ships BSD sed/grep; nf-core version-capture snippets assume GNU syntax
// (e.g. `sed -n '1{s/.../;p}'`), which BSD sed rejects. Prepend a small GNU
// coreutils env to every task's PATH so those snippets work. NXF_GNU_TOOLS is
// exported by pipelines/env.sh.
process {
    // Prepend BOTH the GNU coreutils bin AND the conda/mamba shim dir
    // (pipelines/bin). The shim dir is essential: Nextflow's own task launcher
    // runs `conda info --json` to locate the activate script, and that only
    // works if our micromamba `conda` shim is on the task's PATH.
    beforeScript = { "export PATH=\"${System.getenv('NXF_GNU_TOOLS') ?: ''}:${System.getenv('NXF_SHIM_BIN') ?: ''}:\$PATH\"" }
}
