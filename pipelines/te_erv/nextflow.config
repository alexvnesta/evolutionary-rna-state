/*
 * Module config for the TE/ERV subworkflow. Combine with the machine profile:
 *   nextflow run pipelines/te_erv/main.nf -profile conda \
 *     -c pipelines/conf/mac_arm64.config
 * (the machine config sets conda.enabled, executor limits, and STAR resources;
 *  this file only binds the tool env and per-process resource labels.)
 */

// Parameter defaults (always present regardless of entrypoint / -c ordering).
params.star_extra_args          = params.star_extra_args          ?: ''
params.telescope_extra_args     = params.telescope_extra_args     ?: ''
params.tetranscripts_extra_args = params.tetranscripts_extra_args ?: ''

// Bind every process in this workflow to the single tool environment.
// One environment.yml keeps the arm64 solve verified once and reused.
process {
    conda = "${projectDir}/environment.yml"

    withName: 'BOWTIE2_BUILD|BOWTIE2_ALIGN_MULTI' {
        cpus     = 12
        memory   = 16.GB
        maxForks = 1
    }
    withName: 'TELESCOPE_ASSIGN|TETRANSCRIPTS_COUNT' {
        cpus   = 4
        memory = 10.GB
    }
    withName: 'MERGE_TELESCOPE|MERGE_TETRANSCRIPTS' {
        cpus   = 2
        memory = 8.GB
    }
}
