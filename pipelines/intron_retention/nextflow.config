/*
 * Local config for the standalone INTRON_RETENTION subworkflow.
 * Compose with the repo's Mac profile:
 *   -c pipelines/conf/mac_arm64.config -c pipelines/intron_retention/nextflow.config
 * (mac_arm64.config supplies conda.enabled, the local executor caps, and STAR
 *  resource ceilings; this file only sets the IR process labels.)
 *
 * Scripts under bin/ are auto-added to PATH by Nextflow for this projectDir.
 */

conda.enabled = true
conda.channels = ['conda-forge', 'bioconda']

// IR parameter defaults -- defined here so they resolve whether the workflow is
// launched via main.nf or included into another pipeline. main.nf may override.
params.ir_min_intron_len      = 50
params.ir_min_gene_exon_count = 20
params.ir_high_threshold      = 0.1
params.ir_strandedness        = 2

process {
    // featureCounts on introns/exons: I/O + CPU bound, modest memory.
    withName: 'FEATURECOUNTS_IR|FEATURECOUNTS_EXON' {
        cpus     = 4
        memory   = 10.GB
        maxForks = 2
    }
    // GTF parsing (pure python, whole-genome exon mask): single-pass, light.
    withName: 'MAKE_INTRON_SAF' {
        cpus     = 1
        memory   = 8.GB
    }
    // IR ratio + matrix merge: pandas, small.
    withName: 'COMPUTE_IR_RATIO|MERGE_IR_MATRIX' {
        cpus     = 1
        memory   = 6.GB
    }
    // label fallbacks (used if this config is applied without mac_arm64.config)
    withLabel: 'process_low'    { cpus = 1; memory = 6.GB  }
    withLabel: 'process_medium' { cpus = 4; memory = 10.GB }
}
