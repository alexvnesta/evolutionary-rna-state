.idea/
*.swp

# --- Secrets — never commit ---
.env
.env.*
*.pem
*.key
credentials.json

# --- Sandbox git metadata (this checkout keeps git metadata in .gitmeta,
#     not .git, because the build sandbox forbids any path named .git.
#     On a normal machine rename .gitmeta -> .git for a standard repo.) ---
.gitmeta/
